<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 筛选栏 -->
    <LinearLayout
        android:id="@+id/filter_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_all"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="全部任务"
            android:textAlignment="center"
            android:textSize="12sp"
            app:chipCornerRadius="8dp"
            app:chipMinHeight="32dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_completed"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:text="已完成 (0)"
            android:textAlignment="center"
            android:textSize="12sp"
            app:chipCornerRadius="8dp"
            app:chipMinHeight="32dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_running"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:text="进行中 (0)"
            android:textAlignment="center"
            android:textSize="12sp"
            app:chipCornerRadius="8dp"
            app:chipMinHeight="32dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_failed"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="任务失败 (0)"
            android:textAlignment="center"
            android:textSize="12sp"
            app:chipCornerRadius="8dp"
            app:chipMinHeight="32dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/download_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/filter_bar">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="全部文件"
            android:textColor="@color/gray"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/layout_concurrent_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="同时下载数："
                android:textColor="@color/gray"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_concurrent_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textColor="@color/blue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_menu_categories"
                android:contentDescription="下拉选择" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_clear_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="全部清除"
            android:textColor="@color/gray"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 空态 -->
    <LinearLayout
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

<!--                <ImageView-->
<!--                    android:layout_width="80dp"-->
<!--                    android:layout_height="80dp"-->
<!--                    android:src="@android:drawable/ic_mesnu_download"/>-->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_download_1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="暂无下载任务"
            android:textColor="@color/gray"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_downloads"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/download_count"
        app:layout_constraintVertical_bias="1.0"
        tools:layout_editor_absoluteX="94dp" />

</androidx.constraintlayout.widget.ConstraintLayout>